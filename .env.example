# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Your deployment URL (no trailing slash)
NEXTAUTH_URL=https://imperfect-sage.vercel.app

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications
# Redirect URI to set in Discord: https://imperfect-sage.vercel.app/api/auth/callback/discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─── Approved roster members ─────────────────────────────────────────────────
# Comma-separated list of Discord user IDs allowed to access Team Hub.
# To find a Discord ID: enable Developer Mode in Discord → right-click a user → Copy User ID
# Leave empty to allow ALL Discord users who can authenticate (not recommended for production).
APPROVED_DISCORD_IDS=123456789012345678,987654321098765432

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
# If not set, the app falls back to local JSON files in /data (dev only).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Management Dashboard access ──────────────────────────────────────────────
# The /management section is restricted to users with role = 'admin' in the
# players table (set directly in Supabase: UPDATE players SET role = 'admin'
# WHERE discord_id = 'YOUR_DISCORD_ID').
# No additional env vars are needed — the role check is DB-backed.

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# Create a project at sentry.io, then copy the DSN from Settings → Client Keys.
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (client-side error capture).
# SENTRY_DSN is server-only. You can set both to the same value.
# Leave blank to disable Sentry (no errors will be tracked).
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
# Optional: upload source maps for readable stack traces in Sentry
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─── Cron job secret ──────────────────────────────────────────────────────────
# Protects /api/cron/reminders. Set in your cron scheduler as header x-cron-secret.
# Generate: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here
